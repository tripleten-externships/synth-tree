{
  "name": "skilltree-monorepo",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:validate": "pnpm --filter ./apps/api prisma validate",
    "db:migrate:dev": "pnpm --filter ./apps/api prisma migrate dev",
    "db:studio": "pnpm --filter api prisma studio",
    "dev": "pnpm db:start && pnpm --filter ./packages/theme build && pnpm --filter ./packages/ui build && pnpm --parallel --filter admin-dashboard --filter @skilltree/client-frontend --filter api dev",
    "storybook": "pnpm --filter ./packages/ui storybook",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check"
  },
  "packageManager": "pnpm@10.17.1",
  "devDependencies": {
    "@apollo/client": "^4.0.9",
    "@eslint/js": "^9.36.0",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "graphql": "^16.11.0"
  }
}
