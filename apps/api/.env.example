# ─── Firebase Admin (server-side) ───────────────────────────────────────────
#
# RECOMMENDED — point at the local Firebase project's service-account JSON.
# Grab the JSON from the team knowledge base and drop it into:
#   apps/api/scripts/credentials/firebase-local-service-account.json
# (the credentials/ folder is gitignored). See docs/engineering/local-auth.md.
FIREBASE_SERVICE_ACCOUNT_PATH=./scripts/credentials/firebase-local-service-account.json

# Alternatively (e.g. in CI/CD where secrets come from a secret store), the
# three values can be provided individually. Only one of the two methods is
# needed; FIREBASE_SERVICE_ACCOUNT_PATH wins if set.
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Public Firebase Web API key — used by scripts/createLocalUser.ts to mint
# real Firebase ID tokens. Find it at:
#   Firebase Console → Project Settings → General → Your apps → Web app → apiKey
# (this value is also what the frontend uses as VITE_FIREBASE_API_KEY)
FIREBASE_API_KEY=

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/synthtree?schema=public"
