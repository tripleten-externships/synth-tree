FIREBASE_PRIVATE_KEY='private_key_value'
FIREBASE_CLIENT_EMAIL='client@email.com'
FIREBASE_PROJECT_ID='project-id'

# Database Configuration
# Copy this file to .env and update the values as needed

# PostgreSQL connection string for Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/skilltree?schema=public"

# For production, use a secure password and appropriate host
# DATABASE_URL="postgresql://username:secure_password@production_host:5432/skilltree?schema=public"

# ---------------------------------------------------------------------------
# Media uploads (ST-70)
# ---------------------------------------------------------------------------
# S3 bucket used to store images and videos uploaded by admins.
MEDIA_BUCKET_NAME="synth-tree-dev-media"

# Public base URL for the media bucket.
# In production this should be your CloudFront distribution URL.
# In local dev it can be the raw S3 URL.
# Example: https://media.synth-tree.com  OR  https://synth-tree-dev-media.s3.amazonaws.com
MEDIA_PUBLIC_BASE_URL="https://synth-tree-dev-media.s3.amazonaws.com"

# AWS region where the bucket lives.
AWS_REGION="us-east-1"

# Local dev only — in ECS the task role provides credentials automatically.
# Leave blank when deploying (IAM role on the container handles auth).
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""