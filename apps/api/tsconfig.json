{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "esModuleInterop": true,
     "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@graphql/*": ["./src/graphql/*"],
      "@lib/*": ["./src/lib/*"]
    }
  },
  "include": ["src"]
}