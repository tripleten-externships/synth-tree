# Synth Tree admin dashboard — local development env template.
#
# IMPORTANT: these values must point at the *local* Firebase project (the one
# whose service-account JSON your team uses for local development). Get them
# from the team knowledge base. Never check real values into the repo.
#
# Find the values at:
#   Firebase Console → Project Settings → General → Your apps → Web app → Config

# ─── Firebase ───────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Optional: Google Analytics measurement ID
# VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Set to "true" to use the local Firebase Auth emulator on :9099 instead of
# the real Firebase project. Default false — most local dev uses the real
# project, since that's how multiple students share user data.
VITE_USE_FIREBASE_EMULATOR=false

# ─── GraphQL API ────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000/graphql
